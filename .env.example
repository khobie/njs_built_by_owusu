# Copy this file to ".env" in the same folder (name must be exactly .env).

# --- Option A: PostgreSQL via Docker (recommended on Windows) ---
# 1. Run:  docker compose up -d
# 2. Use this URL as-is (matches docker-compose.yml):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/njs_form_system?schema=public"

# --- Option B: Your own PostgreSQL / cloud ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
