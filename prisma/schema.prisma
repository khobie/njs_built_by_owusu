generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ElectoralArea {
  id              String           @id @default(cuid())
  name            String           @unique
  code            String           @unique
  pollingStations PollingStation[]
  candidates      Candidate[]
  userAssignments UserElectoralArea[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("electoral_areas")
}

model PollingStation {
  name            String
  code            String        @id
  electoralAreaId String
  electoralArea   ElectoralArea @relation(fields: [electoralAreaId], references: [id])
  candidates      Candidate[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("polling_stations")
}

model Candidate {
  id                 String            @id @default(cuid())
  formNumber         String            @unique
  surname            String
  firstName          String
  middleName         String?
  phoneNumber        String
  age                Int?
  electoralAreaId    String
  electoralArea      ElectoralArea     @relation(fields: [electoralAreaId], references: [id])
  pollingStationCode String?
  pollingStation     PollingStation?  @relation(fields: [pollingStationCode], references: [code])
  position           String
  delegateType       String            @default("NEW")
  comment            String?
  status             String            @default("ISSUED")
  verificationStatus String            @default("NOT_VERIFIED")
  contestStatus      String            @default("PENDING")
  reports            CandidateReport[]
  vettingQuestions   VettingQuestion[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([phoneNumber])
  @@map("candidates")
}

model CandidateReport {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorName  String
  reportType  String    @default("GENERAL")
  content     String
  isResolved  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("candidate_reports")
}

model VettingQuestion {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  questionKey String
  question    String
  response    Boolean
  notes       String?
  verifiedBy  String
  verifiedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([candidateId, questionKey])
  @@map("vetting_questions")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("ADMIN")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  electoralAreas     UserElectoralArea[]
  eaPortalAreas      UserEaPortalArea[]
  eaPortalIssuedForms EaPortalIssuedForm[]

  @@map("users")
}

/// Electoral Area Management Portal — logically separate from delegate/polling DB tables; same Postgres instance.
model EaPortalArea {
  id               String   @id @default(cuid())
  name             String
  constituency     String
  district         String
  region           String
  /// Optional link to delegate module `ElectoralArea.code` (integration / polling station directory).
  delegateAreaCode String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  records     EaPortalRecord[]
  userLinks   UserEaPortalArea[]
  activities  EaPortalActivity[]
  issuedForms EaPortalIssuedForm[]

  @@unique([name, constituency, district, region])
  @@index([delegateAreaCode])
  @@map("ea_portal_areas")
}

model EaPortalRecord {
  id                 String        @id @default(cuid())
  fullName           String
  phone              String
  role               String
  electoralAreaId    String?
  electoralArea      EaPortalArea? @relation(fields: [electoralAreaId], references: [id], onDelete: SetNull)
  pollingStationCode String?
  pollingStationName String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  activities EaPortalActivity[]

  @@index([electoralAreaId])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
  @@map("ea_portal_records")
}

/// Electoral Area **portal** form issuing — separate from delegate `Candidate` / nomination forms.
model EaPortalIssuedForm {
  id                   String       @id @default(cuid())
  fullName             String
  /// Normalized (whitespace stripped) for consistent duplicate detection.
  phone                String
  gender               String?
  address              String?
  electoralAreaId      String
  electoralArea        EaPortalArea @relation(fields: [electoralAreaId], references: [id], onDelete: Restrict)
  pollingStationCode   String?
  pollingStationName   String?
  position             String
  formNumber           String       @unique
  applicantType        String
  status               String       @default("PENDING")
  issuedByUserId       String
  issuedBy             User         @relation(fields: [issuedByUserId], references: [id], onDelete: Restrict)
  issuedAt             DateTime     @default(now())
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([electoralAreaId, position, phone])
  @@index([electoralAreaId])
  @@index([position])
  @@index([status])
  @@index([applicantType])
  @@index([issuedAt])
  @@map("ea_portal_issued_forms")
}

model UserEaPortalArea {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  eaPortalAreaId String
  area           EaPortalArea @relation(fields: [eaPortalAreaId], references: [id], onDelete: Cascade)
  assignedAt     DateTime     @default(now())

  @@unique([userId, eaPortalAreaId])
  @@map("user_ea_portal_areas")
}

model EaPortalActivity {
  id          String          @id @default(cuid())
  action      String
  details     String?
  actorUserId String?
  areaId      String?
  area        EaPortalArea?   @relation(fields: [areaId], references: [id], onDelete: SetNull)
  recordId    String?
  record      EaPortalRecord? @relation(fields: [recordId], references: [id], onDelete: SetNull)
  createdAt   DateTime        @default(now())

  @@index([createdAt])
  @@map("ea_portal_activities")
}

model UserElectoralArea {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  areaCode String
  area     ElectoralArea @relation(fields: [areaCode], references: [code])
  assignedAt DateTime @default(now())

  @@unique([userId, areaCode])
  @@map("user_electoral_areas")
}

// Role constants: SUPER_ADMIN, ADMIN, FORM_ISSUER, VETTING_PANEL
